# Generated by Cargo
# will have compiled files and executables
debug/
target/

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Completion scripts
completions/

# manpage output
man/

# Directory generated by direnv when using a nix shell
.direnv/

# VS Code files
.vscode/launch.json
.vscode/tasks.json

