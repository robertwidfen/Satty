{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug executable 'satty'",
            "cargo": {
                "args": [
                    "build",
                    "--bin=satty",
                    "--package=satty"
                ],
                "filter": {
                    "name": "satty",
                    "kind": "bin"
                }
            },
            "args": [
                "--config",
                "config.toml",
                "--filename",
                "assets/usage.gif",
                "--output-filename",
                "/tmp/out.png"
            ],
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug unit tests in executable 'satty'",
            "cargo": {
                "args": [
                    "test",
                    "--no-run",
                    "--bin=satty",
                    "--package=satty"
                ],
                "filter": {
                    "name": "satty",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        }
    ]
}